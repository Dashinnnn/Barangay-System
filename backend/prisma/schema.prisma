generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String
  firstName   String
  lastName    String
  role        Role      @default(STAFF)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("users")
}

model Purok {
  id            String     @id @default(cuid())
  name          String     @unique
  description   String?
  leaderName    String?
  contactNumber String?

  residents     Resident[]

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@map("puroks")
}

model Resident {
  id                String            @id @default(cuid())
  firstName         String
  middleName        String?
  lastName          String
  suffix            String?
  dateOfBirth       DateTime
  gender            Gender
  civilStatus       CivilStatus
  occupation        String?
  contactNumber     String?
  email             String?

  purokId           String
  purok             Purok             @relation(fields: [purokId], references: [id])

  documentRequests  DocumentRequest[]

  houseNumber       String?
  street            String?

  voterStatus       Boolean           @default(false)
  isHouseholdHead   Boolean           @default(false)

  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@map("residents")
}

model DocumentRequest {
  id              String         @id @default(cuid())
  residentId      String
  resident        Resident       @relation(fields: [residentId], references: [id])

  documentType    DocumentType
  purpose         String
  status          RequestStatus  @default(PENDING)
  
  requestedAt     DateTime       @default(now())
  reviewedAt      DateTime?
  releasedAt      DateTime?
  
  reviewedBy      String?
  notes           String?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@map("document_requests")
}

enum Role {
  ADMIN
  CAPTAIN
  SECRETARY
  STAFF
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum CivilStatus {
  SINGLE
  MARRIED
  WIDOWED
  DIVORCED
  SEPARATED
}

enum DocumentType {
  BARANGAY_CLEARANCE
  CERTIFICATE_OF_INDIGENCY
  CERTIFICATE_OF_RESIDENCY
  CERTIFICATE_OF_BIRTH
  GOOD_MORAL_CHARACTER
  OTHER
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  RELEASED
}