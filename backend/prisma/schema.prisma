generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== USERS & ROLES ====================
model User {
  id            String        @id @default(cuid())
  email         String        @unique
  password      String
  firstName     String
  lastName      String
  role          Role          @default(STAFF)
  isActive      Boolean       @default(true)
  
  filedCases    BlotterCase[] @relation("FiledBy")
  assignedCases BlotterCase[] @relation("AssignedTo")
  hearingsLed   Hearing[]
  caseLogs      CaseLog[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("users")
}

// ==================== BARANGAY STRUCTURE ====================
model Purok {
  id            String     @id @default(cuid())
  name          String     @unique
  description   String?
  leaderName    String?
  contactNumber String?

  residents     Resident[]

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@map("puroks")
}

// ==================== RESIDENTS ====================
model Resident {
  id              String            @id @default(cuid())
  firstName       String
  middleName      String?
  lastName        String
  suffix          String?
  dateOfBirth     DateTime
  gender          Gender
  civilStatus     CivilStatus
  occupation      String?
  contactNumber   String?
  email           String?
  houseNumber     String?
  street          String?
  
  purokId         String
  purok           Purok             @relation(fields: [purokId], references: [id])

  voterStatus     Boolean           @default(false)
  isHouseholdHead Boolean           @default(false)

  documentRequests DocumentRequest[]
  caseParties      CaseParty[]

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@map("residents")
}

// ==================== DOCUMENT REQUESTS ====================
model DocumentRequest {
  id           String        @id @default(cuid())
  residentId   String
  resident     Resident      @relation(fields: [residentId], references: [id])

  documentType DocumentType
  purpose      String
  status       RequestStatus @default(PENDING)

  requestedAt  DateTime      @default(now())
  reviewedAt   DateTime?
  releasedAt   DateTime?

  reviewedBy   String?       // User ID (optional reference)
  notes        String?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("document_requests")
}

// ==================== BLOTTER / KATARUNGANG PAMBARANGAY ====================
model BlotterCase {
  id              String        @id @default(cuid())
  caseNumber      String        @unique
  title           String
  incidentType    IncidentType
  status          CaseStatus    @default(FILED)
  priority        Priority      @default(NORMAL)

  incidentDate    DateTime
  incidentTime    String?
  incidentPlace   String
  summary         String        @db.Text
  remarks         String?       @db.Text

  // Parties
  complaints      CaseParty[]   @relation("Complaints")
  respondents     CaseParty[]   @relation("Respondents")
  witnesses       CaseParty[]   @relation("Witnesses")

  hearings        Hearing[]
  settlements     Settlement[]
  documents       BlotterDocument[]
  logs            CaseLog[]

  // Tracking
  filedById       String
  filedBy         User          @relation("FiledBy", fields: [filedById], references: [id])
  
  assignedToId    String?
  assignedTo      User?         @relation("AssignedTo", fields: [assignedToId], references: [id])

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("blotter_cases")
}

model CaseParty {
  id            String      @id @default(cuid())

  role          PartyRole

  // If registered resident
  residentId    String?
  resident      Resident?   @relation(fields: [residentId], references: [id])

  // For walk-ins / non-residents
  firstName     String
  middleName    String?
  lastName      String
  suffix        String?
  address       String
  contactNumber String?
  age           Int?
  gender        Gender?
  civilStatus   CivilStatus?
  occupation    String?

  statement     String?     @db.Text

  // Relations to case
  complainantCaseId String?
  complainantCase   BlotterCase? @relation("Complaints", fields: [complainantCaseId], references: [id])

  respondentCaseId  String?
  respondentCase    BlotterCase? @relation("Respondents", fields: [respondentCaseId], references: [id])

  witnessCaseId     String?
  witnessCase       BlotterCase? @relation("Witnesses", fields: [witnessCaseId], references: [id])

  createdAt     DateTime    @default(now())

  @@map("case_parties")
}

model Hearing {
  id            String         @id @default(cuid())
  caseId        String
  case          BlotterCase    @relation(fields: [caseId], references: [id])

  hearingNumber Int
  scheduledDate DateTime
  actualDate    DateTime?
  venue         String?
  outcome       HearingOutcome?
  notes         String?        @db.Text

  conductedById String
  conductedBy   User           @relation(fields: [conductedById], references: [id])

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("hearings")
}

model Settlement {
  id             String         @id @default(cuid())
  caseId         String
  case           BlotterCase    @relation(fields: [caseId], references: [id])

  settlementDate DateTime
  type           SettlementType
  terms          String         @db.Text
  isSigned       Boolean        @default(false)

  createdAt      DateTime       @default(now())

  @@map("settlements")
}

model BlotterDocument {
  id         String             @id @default(cuid())
  caseId     String
  case       BlotterCase        @relation(fields: [caseId], references: [id])

  type       BlotterDocumentType
  fileName   String
  filePath   String

  uploadedAt DateTime           @default(now())

  @@map("blotter_documents")
}

model CaseLog {
  id           String      @id @default(cuid())
  caseId       String
  case         BlotterCase @relation(fields: [caseId], references: [id])

  action       String
  performedById String
  performedBy  User        @relation(fields: [performedById], references: [id])

  performedAt  DateTime    @default(now())

  @@map("case_logs")
}

// ==================== ENUMS ====================
enum Role {
  ADMIN
  CAPTAIN
  SECRETARY
  STAFF
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum CivilStatus {
  SINGLE
  MARRIED
  WIDOWED
  DIVORCED
  SEPARATED
}

enum DocumentType {
  BARANGAY_CLEARANCE
  CERTIFICATE_OF_INDIGENCY
  CERTIFICATE_OF_RESIDENCY
  CERTIFICATE_OF_BIRTH
  GOOD_MORAL_CHARACTER
  OTHER
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  RELEASED
}

enum IncidentType {
  PHYSICAL_INJURY
  ORAL_DEFAMATION
  THEFT
  TRESPASSING
  NUISANCE
  PROPERTY_DAMAGE
  DOMESTIC_DISPUTE
  NOISE_COMPLAINT
  DEBT_COLLECTION
  ESTAFA
  OTHERS
}

enum CaseStatus {
  FILED
  UNDER_MEDIATION
  PENDING_HEARING
  SETTLED
  UNSETTLED
  REFERRED_TO_COURT
  DISMISSED
  ARCHIVED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum PartyRole {
  COMPLAINANT
  RESPONDENT
  WITNESS
}

enum HearingOutcome {
  SETTLED
  FAILED
  POSTPONED
  PENDING
  NO_SHOW
}

enum SettlementType {
  AMICABLE
  ARBITRATION_AWARD
  REFERRED_TO_LUPONG_TAGAPAMAYAPA
  REFERRED_TO_COURT
  DISMISSED
}

enum BlotterDocumentType {
  SWORN_STATEMENT
  SUMMONS
  NOTICE_OF_HEARING
  CERTIFICATE_TO_FILE_ACTION
  SETTLEMENT_AGREEMENT
  PHOTO_EVIDENCE
  OTHER
}